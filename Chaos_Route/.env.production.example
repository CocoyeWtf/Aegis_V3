DEBUG=false
DATABASE_URL=postgresql+asyncpg://cmro:CHANGE_ME_STRONG_PASSWORD@db:5432/cmro
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
SECRET_KEY=<generer-avec-openssl-rand-hex-32>
# Compte superadmin initial — cree UNIQUEMENT si la base est vide.
# Obligatoire sur base vide (sinon refus de demarrer). >= 14 caracteres,
# 3 classes (min/maj/chiffre/symbole). Rotation forcee au 1er login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=<mot-de-passe-fort-14-caracteres-minimum>
CORS_ORIGINS=["https://chaosroute.chaosmanager.tech"]
# Passerelle SMS Termux — clé partagée serveur ↔ téléphone
SMS_API_KEY=<generer-avec-openssl-rand-hex-16>
# URL du serveur CHAOS vue depuis la passerelle SMS Termux
SMS_GATEWAY_SERVER_URL=https://chaosroute.chaosmanager.tech/api/sms
